{
  "name": "DiffGate",
  "url": "https://github.com/srbsa/diffgate",
  "hook_attributes": {
    "url": "https://YOUR-DEPLOYMENT/webhook",
    "active": true
  },
  "redirect_url": "https://YOUR-DEPLOYMENT/setup/callback",
  "public": false,
  "default_events": ["pull_request"],
  "default_permissions": {
    "contents": "read",
    "pull_requests": "write",
    "statuses": "write",
    "metadata": "read"
  },
  "description": "Diff-aware, three-tiered code review. Reviews only changed lines and gates high-impact (orange) changes."
}
